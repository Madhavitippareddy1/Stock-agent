{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadFinancialReports",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket"
      ],
      "Resource": "arn:aws:s3:::stock-agent-reports-666127452756-eu-west-2"
    },
    {
      "Sid": "ReadFinancialReportObjects",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject"
      ],
      "Resource": "arn:aws:s3:::stock-agent-reports-666127452756-eu-west-2/financial-reports/*"
    },
    {
      "Sid": "InvokeBedrock",
      "Effect": "Allow",
      "Action": [
        "bedrock:InvokeModel",
        "bedrock:InvokeModelWithResponseStream"
      ],
      "Resource": "*"
    }
  ]
}
