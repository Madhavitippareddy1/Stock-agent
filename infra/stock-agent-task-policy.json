{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadFinancialReports",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket"
      ],
      "Resource": "arn:aws:s3:::dev-dsmay-stock-agent-bucket"
    },
    {
      "Sid": "ReadFinancialReportObjects",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject"
      ],
      "Resource": "arn:aws:s3:::dev-dsmay-stock-agent-bucket/financial-reports/*"
    },
    {
      "Sid": "InvokeBedrock",
      "Effect": "Allow",
      "Action": [
        "bedrock:InvokeModel",
        "bedrock:InvokeModelWithResponseStream"
      ],
      "Resource": "*"
    },
    {
      "Sid": "QueryOpenSearchServerless",
      "Effect": "Allow",
      "Action": [
        "aoss:APIAccessAll"
      ],
      "Resource": "arn:aws:aoss:eu-west-2:666127452756:collection/8sxalipy464p1anut4s6"
    }
  ]
}
