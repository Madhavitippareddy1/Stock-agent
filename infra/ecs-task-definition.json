{
  "family": "stock-agent",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "ECS_EXECUTION_ROLE_ARN",
  "taskRoleArn": "ECS_TASK_ROLE_ARN",
  "containerDefinitions": [
    {
      "name": "stock-agent",
      "image": "ECR_IMAGE_URI",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8501,
          "hostPort": 8501,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {"name": "AWS_REGION", "value": "eu-west-2"},
        {"name": "BEDROCK_MODEL_ID", "value": "amazon.nova-lite-v1:0"},
        {"name": "BEDROCK_EMBEDDING_MODEL_ID", "value": "amazon.titan-embed-text-v2:0"},
        {"name": "REPORTS_BUCKET", "value": "REPORTS_BUCKET_VALUE"},
        {"name": "REPORTS_PREFIX", "value": "financial-reports"}
      ],
      "secrets": [
        {
          "name": "NEWS_API_KEY",
          "valueFrom": "NEWS_API_SECRET_ARN"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/stock-agent",
          "awslogs-region": "eu-west-2",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "python -c \"import urllib.request; urllib.request.urlopen('http://localhost:8501/_stcore/health')\" || exit 1"
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 30
      }
    }
  ]
}
