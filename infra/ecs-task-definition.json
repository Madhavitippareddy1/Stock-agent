{
  "family": "stock-agent",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::666127452756:role/stock-agent-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::666127452756:role/stock-agent-ecs-task-role",
  "containerDefinitions": [
    {
      "name": "stock-agent",
      "image": "666127452756.dkr.ecr.eu-west-2.amazonaws.com/dev-dsmay-stock-agent-repo:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8501,
          "hostPort": 8501,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {"name": "AWS_REGION", "value": "eu-west-2"},
        {"name": "BEDROCK_MODEL_ID", "value": "amazon.nova-lite-v1:0"},
        {"name": "BEDROCK_EMBEDDING_MODEL_ID", "value": "amazon.titan-embed-text-v2:0"},
        {"name": "EMBEDDING_DIMENSION", "value": "1024"},
        {"name": "BEDROCK_INPUT_COST_PER_1M_TOKENS", "value": "0.06"},
        {"name": "BEDROCK_OUTPUT_COST_PER_1M_TOKENS", "value": "0.24"},
        {"name": "BEDROCK_EMBEDDING_COST_PER_1M_TOKENS", "value": "0.02"},
        {"name": "OPENSEARCH_ENDPOINT", "value": "https://8sxalipy464p1anut4s6.eu-west-2.aoss.amazonaws.com"},
        {"name": "OPENSEARCH_INDEX", "value": "financial-report-chunks"},
        {"name": "REPORTS_BUCKET", "value": "dev-dsmay-stock-agent-bucket"},
        {"name": "REPORTS_PREFIX", "value": "financial-reports"},
        {"name": "SEC_USER_AGENT", "value": "StockAgent/0.1 madhavitippareddy1@example.com"},
        {"name": "STOCK_UNIVERSE", "value": "NVDA,GOOGL,AAPL,MSFT,AMZN,META,AVGO,TSLA,COST,NFLX"},
        {"name": "LANGFUSE_ENABLED", "value": "true"},
        {"name": "LANGFUSE_BASE_URL", "value": "https://cloud.langfuse.com"},
        {"name": "LANGFUSE_ENVIRONMENT", "value": "production"},
        {"name": "LANGFUSE_CAPTURE_CONTENT", "value": "false"},
        {"name": "LANGFUSE_SAMPLE_RATE", "value": "1.0"}
      ],
      "secrets": [
        {
          "name": "LANGFUSE_PUBLIC_KEY",
          "valueFrom": "arn:aws:secretsmanager:eu-west-2:666127452756:secret:dev/dsmay/stock-agent/langfuse-yR9JUe:public_key::"
        },
        {
          "name": "LANGFUSE_SECRET_KEY",
          "valueFrom": "arn:aws:secretsmanager:eu-west-2:666127452756:secret:dev/dsmay/stock-agent/langfuse-yR9JUe:secret_key::"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/stock-agent",
          "awslogs-region": "eu-west-2",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "python -c \"import urllib.request; urllib.request.urlopen('http://localhost:8501/_stcore/health')\" || exit 1"
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 30
      }
    }
  ]
}
